# ============================================================
# VA Project Environment Configuration
# ============================================================
# Copy this file to .env.project and fill in your values.
# The #va-setup wizard will do this for you automatically.
# ============================================================

# --- Project Identity ---
PROJECT_NAME=
PROJECT_DOMAIN=                    # healthcare / benefits / logistics / administration
PROJECT_TYPE=                      # demo / pilot / production
VA_OFFICE=                         # OIT / OCTO / VHA / VBA / NCA
VISN_FACILITY=                     # VISN number or facility name

# --- Azure Government ---
AZURE_GOV_REGION=usgovvirginia     # usgovvirginia / usgovarizona
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=                   # VA Azure Government tenant

# --- Compliance ---
FEDRAMP_LEVEL=High                 # High / Moderate / Low
FISMA_IMPACT=High                  # High / Moderate / Low
HANDLES_PHI=                       # true / false
ATO_REQUIRED=                      # true / false / inherited
NIST_BASELINE=High                 # High / Moderate / Low

# --- Authentication ---
AUTH_METHOD=PIV_CAC                # PIV_CAC / AZURE_AD / MANAGED_IDENTITY
AZURE_CLIENT_ID=
AZURE_SP_SECRET_EXPIRES=           # YYYY-MM-DD — for SP expiration warnings

# --- VistA Integration ---
VISTA_INTEGRATION=false            # true / false
VISTA_GATEWAY_URL=                 # If applicable

# --- Tech Stack ---
TECH_STACK=python                  # python / nodejs / both
GIT_HOST=github                    # github / azure-devops / va-github-enterprise
CICD_PLATFORM=github-actions       # github-actions / azure-pipelines

# --- Infrastructure State (auto-populated by #infra-sync) ---
STORAGE_ACCOUNT_NAME=
COSMOS_DB_ACCOUNT=
KEY_VAULT_NAME=
APP_SERVICE_NAME=
AI_SEARCH_NAME=
OPENAI_ENDPOINT=
INFRA_LAST_SYNC=                   # YYYY-MM-DD — when infra-sync last ran
