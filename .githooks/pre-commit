#!/bin/bash
# Pre-commit hook: Secret scanning + lint check
# Installed by: python scripts/setup-git-hooks.py

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

echo ""
echo "🔒 Pre-commit checks running..."
echo ""

# ── Secret Scanning ──────────────────────────────────────────────────────────

echo "  [1/2] Scanning for secrets..."

# Get staged files only
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo -e "  ${GREEN}✅ No staged files to check${NC}"
else
    # Patterns that indicate secrets
    SECRET_PATTERNS=(
        'password\s*='
        'passwd\s*='
        'api_key\s*='
        'apikey\s*='
        'secret\s*='
        'token\s*='
        'access_key\s*='
        'private_key\s*='
        'connection_string\s*='
        'AKIA[0-9A-Z]{16}'
        'sk-[a-zA-Z0-9]{48}'
        'ghp_[a-zA-Z0-9]{36}'
        'xox[bpors]-[a-zA-Z0-9-]+'
        '[0-9]{3}-[0-9]{2}-[0-9]{4}'
    )

    # Files to skip
    SKIP_PATTERN='\.env\.example$|\.gitignore$|\.githooks/|setup-git-hooks\.py|\.md$|\.lock$'

    for file in $STAGED_FILES; do
        # Skip binary files, excluded patterns, and non-existent files
        if [[ "$file" =~ $SKIP_PATTERN ]] || [ ! -f "$file" ]; then
            continue
        fi

        for pattern in "${SECRET_PATTERNS[@]}"; do
            matches=$(grep -inE "$pattern" "$file" 2>/dev/null || true)
            if [ -n "$matches" ]; then
                echo -e "  ${RED}❌ Possible secret in $file:${NC}"
                echo "$matches" | head -3 | while read -r line; do
                    echo -e "     ${YELLOW}$line${NC}"
                done
                BLOCKED=1
            fi
        done
    done

    if [ $BLOCKED -eq 0 ]; then
        echo -e "  ${GREEN}✅ No secrets detected${NC}"
    fi
fi

# ── Lint Check ───────────────────────────────────────────────────────────────

echo "  [2/2] Running lint check..."

# Only lint if ruff is available and there are Python files staged
PYTHON_FILES=$(echo "$STAGED_FILES" | grep '\.py$' || true)

if [ -n "$PYTHON_FILES" ]; then
    if command -v ruff &> /dev/null; then
        if ! ruff check $PYTHON_FILES 2>/dev/null; then
            echo -e "  ${RED}❌ Lint errors found. Run 'ruff check --fix .' to auto-fix.${NC}"
            BLOCKED=1
        else
            echo -e "  ${GREEN}✅ Lint passed${NC}"
        fi
    elif [ -f ".venv/bin/ruff" ]; then
        if ! .venv/bin/ruff check $PYTHON_FILES 2>/dev/null; then
            echo -e "  ${RED}❌ Lint errors found. Run 'ruff check --fix .' to auto-fix.${NC}"
            BLOCKED=1
        else
            echo -e "  ${GREEN}✅ Lint passed${NC}"
        fi
    else
        echo -e "  ${YELLOW}⚠️  ruff not found — skipping lint${NC}"
    fi
else
    echo -e "  ${GREEN}✅ No Python files to lint${NC}"
fi

# ── Result ───────────────────────────────────────────────────────────────────

echo ""
if [ $BLOCKED -ne 0 ]; then
    echo -e "${RED}❌ Commit blocked. Fix the issues above and try again.${NC}"
    echo -e "${YELLOW}   To bypass (not recommended): git commit --no-verify${NC}"
    exit 1
else
    echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
fi
echo ""
